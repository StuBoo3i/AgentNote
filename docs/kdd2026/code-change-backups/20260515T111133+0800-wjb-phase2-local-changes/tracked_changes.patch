+def _to_text(value: Any) -> str:
+    return str(value).strip() if value is not None else ""
+
+
+def _unique(items: list[str]) -> tuple[str, ...]:
+    seen: set[str] = set()
+    ordered: list[str] = []
+    for item in items:
+        if item in seen:
+            continue
+        seen.add(item)
+        ordered.append(item)
+    return tuple(ordered)
+
+
+def _normalize_extensions(raw_value: Any) -> tuple[str, ...]:
+    if raw_value is None:
+        return ()
+    values: list[str]
+    if isinstance(raw_value, str):
+        values = [part.strip() for part in raw_value.split(",") if part.strip()]
+    elif isinstance(raw_value, list):
+        values = [_to_text(item) for item in raw_value if _to_text(item)]
+    else:
+        return ()
+    normalized: list[str] = []
+    for value in values:
+        item = value.lower()
+        if not item.startswith("."):
+            item = f".{item}"
+        normalized.append(item)
+    return _unique(normalized)
+
+
+def _normalize_keywords(raw_value: Any) -> tuple[str, ...]:
+    if raw_value is None:
+        return ()
+    if isinstance(raw_value, str):
+        values = [part.strip() for part in re.split(r"[,\n;|]", raw_value) if part.strip()]
+    elif isinstance(raw_value, list):
+        values = [_to_text(item) for item in raw_value if _to_text(item)]
+    else:
+        return ()
+    return _unique([value.lower() for value in values if value])
+
+
+def _extract_keywords(description: str, name: str, tags: tuple[str, ...]) -> tuple[str, ...]:
+    candidates: list[str] = []
+    quoted_segments = re.findall(r'"([^"]+)"', description)
+    for segment in quoted_segments:
+        candidates.extend([part.strip().lower() for part in segment.split(",") if part.strip()])
+    for token in re.split(r"[-_\s]+", name):
+        token = token.strip().lower()
+        if len(token) >= 3:
+            candidates.append(token)
+    for tag in tags:
+        if tag:
+            candidates.append(tag.lower())
+    return _unique(candidates)
+
+
+def _summarize_playbook(markdown_body: str) -> str:
+    lines = [line.strip() for line in markdown_body.splitlines() if line.strip()]
+    cleaned_lines: list[str] = []
+    for line in lines:
+        if line.startswith("#"):
+            continue
+        normalized = re.sub(r"^[-*]\s+", "", line)
+        normalized = re.sub(r"^\d+\.\s+", "", normalized)
+        cleaned_lines.append(normalized)
+    if not cleaned_lines:
+        return ""
+
+    snippets = cleaned_lines[:4]
+    summary = "; ".join(snippets)
+    summary = re.sub(r"\s+", " ", summary).strip()
+    if len(summary) <= _MAX_PLAYBOOK_CHARS:
+        return summary
+    truncated = summary[: _MAX_PLAYBOOK_CHARS - 3].rstrip()
+    return f"{truncated}..."
+
+
+def parse_skill_markdown(skill_md_path: Path) -> SkillDefinition | None:
+    try:
+        content = skill_md_path.read_text(encoding="utf-8")
+    except OSError:
+        return None
+    content = content.lstrip("\ufeff")
+    match = _FRONTMATTER_RE.match(content)
+    if not match:
+        return None
+
+    frontmatter_text = str(match.group("frontmatter") or "")
+    body = str(match.group("body") or "").strip()
+    try:
+        payload = yaml.safe_load(frontmatter_text) or {}
+    except yaml.YAMLError:
+        return None
+    if not isinstance(payload, dict):
+        return None
+
+    name = _to_text(payload.get("name"))
+    description = _to_text(payload.get("description"))
+    if not name or not description:
+        return None
+
+    tags = _normalize_keywords(payload.get("tags"))
+    trigger_keywords = _normalize_keywords(payload.get("trigger_keywords"))
+    if not trigger_keywords:
+        trigger_keywords = _extract_keywords(description, name, tags)
+    trigger_extensions = _normalize_extensions(
+        payload.get("trigger_extensions")
+        or payload.get("supported_extensions")
+        or payload.get("file_extensions")
+    )
+
+    playbook = _to_text(payload.get("playbook")) or _summarize_playbook(body)
+    required_tools = _normalize_keywords(payload.get("required_tools"))
+    required_knowledge = _normalize_keywords(payload.get("required_knowledge"))
+    version = _to_text(payload.get("version")) or None
+    author = _to_text(payload.get("author")) or None
+
+    return SkillDefinition(
+        name=name,
+        description=description,
+        trigger_extensions=trigger_extensions,
+        trigger_keywords=trigger_keywords,
+        playbook=playbook,
+        path=str(skill_md_path),
+        source="file",
+        tags=tags,
+        required_tools=required_tools,
+        required_knowledge=required_knowledge,
+        version=version,
+        author=author,
+    )
+
+
+def _iter_skill_markdown_files(source_dir: Path, *, recursive: bool) -> list[Path]:
+    if recursive:
+        paths = [path for path in source_dir.glob(f"**/{SKILL_FILE_NAME}") if path.is_file()]
+    else:
+        paths = [path for path in source_dir.glob(f"*/{SKILL_FILE_NAME}") if path.is_file()]
+    return sorted(paths, key=lambda path: path.as_posix())
+
+
+def load_skills_from_sources(
+    source_dirs: Sequence[Path],
+    *,
+    recursive: bool = True,
+) -> tuple[SkillDefinition, ...]:
+    loaded: dict[str, SkillDefinition] = {}
+    for source_dir in source_dirs:
+        resolved_source = source_dir.expanduser().resolve()
+        if not resolved_source.exists() or not resolved_source.is_dir():
+            continue
+        for skill_path in _iter_skill_markdown_files(resolved_source, recursive=recursive):
+            skill = parse_skill_markdown(skill_path)
+            if skill is None:
+                continue
+            if skill.name in loaded:
+                del loaded[skill.name]
+            loaded[skill.name] = skill
+    return tuple(loaded.values())
+
+
+def load_skill_library(
+    *,
+    source_dirs: Sequence[Path] = (),
+    recursive: bool = True,
+    include_builtin: bool = True,
+) -> tuple[SkillDefinition, ...]:
+    loaded_from_files = load_skills_from_sources(source_dirs, recursive=recursive)
+    if include_builtin:
+        merged: dict[str, SkillDefinition] = {skill.name: skill for skill in SKILL_LIBRARY}
+        for skill in loaded_from_files:
+            merged[skill.name] = skill
+        return tuple(merged.values())
+    return loaded_from_files
+
 
